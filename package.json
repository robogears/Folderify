{
  "name": "folderify",
  "version": "0.1.16",
  "description": "Your folders, played like Spotify. A read-only music player where the main folder is your library and each subfolder is a playlist.",
  "author": "William",
  "license": "MIT",
  "main": "./out/main/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "electron-vite dev",
    "preview": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build:unpack": "electron-vite build && electron-builder --dir",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:mobile": "vite build --config vite.mobile.config.ts",
    "ios:sync": "npm run build:mobile && cap sync ios",
    "ios:open": "cap open ios"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "music-metadata": "^11.13.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.0",
    "zustand": "^5.0.0"
  }
}
